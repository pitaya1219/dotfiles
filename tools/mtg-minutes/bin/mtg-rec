#!/usr/bin/env python3
"""
mtg-rec — OBSを使わずにコマンドで会議を2トラック録音する小ツール。
  Track1 = 自分の声  (BlackHole 2ch ← OBS+RNNoise後のクリーン音声)
  Track2 = 相手の声  (BlackHole 16ch ← Multi-Output Device経由)

録音した .mkv はそのまま mtg-minutes に渡せる(2トラック=話者分離つき)。

前提:
  - 通常の会議セットアップ(物理マイク → OBS(RNNoise) → BlackHole 2ch)が動いていること。
    = OBSを起動し、マイクのモニタリングがBlackHole 2chに出ている状態。
    ※ OBSを使わず生マイクで録るなら --self-device "UAB-80" 等で上書き。
  - Multi-Output Device(ヘッドホン + BlackHole 16ch)を作成し、
    通話アプリ/システムの出力先に指定しておくこと(相手の声がBlackHole 16chに乗る)。

使い方:
    mtg-rec                          # 録音開始、Ctrl-C で停止
    mtg-rec --minutes "1on1 田中"     # 停止後そのまま議事録生成まで実行
    mtg-rec --duration 30            # 30秒で自動停止(テスト用)
    mtg-rec --list                   # 録音デバイス一覧
"""
import argparse
import datetime as dt
import os
import re
import signal
import subprocess
import sys
from pathlib import Path

SELF_DEVICE = "BlackHole 2ch"
OTHER_DEVICE = "BlackHole 16ch"
MEETING_OUTPUT_DEVICE = "会議用"
OUT_DIR = Path.home() / "Movies"
MTG_MINUTES = "mtg-minutes"

DEV_RE = re.compile(r"\[(\d+)\]\s+(.+)")


def info(msg):
    print(f"\033[36m▶\033[0m {msg}", file=sys.stderr)


def warn(msg):
    print(f"\033[33m⚠\033[0m {msg}", file=sys.stderr)


def die(msg, code=1):
    print(f"\033[31m✖\033[0m {msg}", file=sys.stderr)
    sys.exit(code)


def get_audio_output():
    """現在のシステム出力デバイス名を返す。SwitchAudioSource がなければ None。"""
    try:
        res = subprocess.run(["SwitchAudioSource", "-c"], capture_output=True, text=True)
        return res.stdout.strip() or None
    except FileNotFoundError:
        return None


def switch_audio_output(device_name):
    """SwitchAudioSource でシステム出力デバイスを切り替える。失敗は warn のみ。"""
    try:
        subprocess.run(["SwitchAudioSource", "-s", device_name], check=True, capture_output=True)
    except FileNotFoundError:
        warn("SwitchAudioSource が見つかりません。出力デバイスの自動切り替えをスキップ")
    except subprocess.CalledProcessError:
        warn(f"出力デバイスの切り替えに失敗: {device_name!r}")


def list_audio_devices():
    """avfoundation のオーディオ入力デバイス [(idx, name), ...]"""
    res = subprocess.run(
        ["ffmpeg", "-f", "avfoundation", "-list_devices", "true", "-i", ""],
        capture_output=True, text=True,
    )
    devices, in_audio = [], False
    for line in res.stderr.splitlines():
        if "AVFoundation audio devices" in line:
            in_audio = True
            continue
        if in_audio:
            m = DEV_RE.search(line)
            if m:
                devices.append((int(m.group(1)), m.group(2).strip()))
    return devices


def resolve(devices, name):
    nl = name.lower()
    for idx, dname in devices:
        if nl in dname.lower():
            return idx, dname
    return None, None


def main():
    ap = argparse.ArgumentParser(description="OBSなしで会議を2トラック録音")
    ap.add_argument("--list", action="store_true", help="録音デバイス一覧を表示して終了")
    ap.add_argument("--self-device", default=SELF_DEVICE, help=f"自分のマイク (既定: {SELF_DEVICE})")
    ap.add_argument("--other-device", default=OTHER_DEVICE, help=f"相手の声 (既定: {OTHER_DEVICE})")
    ap.add_argument("--duration", type=int, default=0, help="指定秒で自動停止(0=Ctrl-Cまで)")
    ap.add_argument("--out", default="", help="出力ファイルパス(既定: ~/Movies/mtg_日時.mkv)")
    ap.add_argument("--minutes", nargs="?", const="", default=None,
                    metavar="TITLE", help="録音停止後に mtg-minutes を実行(タイトル任意)")
    ap.add_argument("--output-device", default=MEETING_OUTPUT_DEVICE,
                    help=f"録音中に切り替えるシステム出力デバイス名 (既定: {MEETING_OUTPUT_DEVICE})")
    ap.add_argument("--no-switch-output", action="store_true",
                    help="システム出力デバイスの自動切り替えをスキップ")
    args = ap.parse_args()

    devices = list_audio_devices()
    if args.list:
        print("録音デバイス一覧:")
        for idx, name in devices:
            tag = ""
            if args.self_device.lower() in name.lower():
                tag = "  ← 自分"
            elif args.other_device.lower() in name.lower():
                tag = "  ← 相手"
            print(f"  [{idx}] {name}{tag}")
        return

    self_idx, self_name = resolve(devices, args.self_device)
    other_idx, other_name = resolve(devices, args.other_device)
    if self_idx is None:
        die(f"自分のマイク '{args.self_device}' が見つかりません。--list で確認を。")
    if other_idx is None:
        die(f"相手デバイス '{args.other_device}' が見つかりません。\n"
            f"  Multi-Output Device作成 & BlackHole 16ch導入を確認してください。--list で確認を。")

    if args.out:
        out = Path(args.out).expanduser()
    else:
        OUT_DIR.mkdir(parents=True, exist_ok=True)
        out = OUT_DIR / f"mtg_{dt.datetime.now().strftime('%Y%m%d_%H%M%S')}.mkv"

    # 単一ffmpegで2入力 → 2トラック録音。
    # 相手(BlackHole 16ch)は先頭2chをモノラルに集約(残り14chは無音のため)。
    cmd = [
        "ffmpeg", "-y",
        "-f", "avfoundation", "-i", f":{self_idx}",
        "-f", "avfoundation", "-i", f":{other_idx}",
        "-filter_complex", "[1:a]pan=mono|c0=0.5*c0+0.5*c1[other]",
        "-map", "0:a", "-map", "[other]",
        "-c:a", "aac", "-b:a", "128k",
    ]
    if args.duration > 0:
        cmd += ["-t", str(args.duration)]
    cmd.append(str(out))

    info(f"自分: [{self_idx}] {self_name}  /  相手: [{other_idx}] {other_name}")
    info(f"録音先: {out}")
    if args.duration > 0:
        info(f"{args.duration}秒で自動停止します")
    else:
        info("録音中… \033[1mCtrl-C で停止\033[0m")

    # 録音前: システム出力デバイスを「会議用」に切り替え
    prev_output = None
    if not args.no_switch_output:
        prev_output = get_audio_output()
        if prev_output == args.output_device:
            prev_output = None  # すでに正しいデバイスなら復元不要
        else:
            info(f"出力デバイス切り替え: {prev_output!r} → {args.output_device!r}")
            switch_audio_output(args.output_device)

    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    try:
        try:
            proc.wait()
        except KeyboardInterrupt:
            # Ctrl-C は ffmpeg にも届く。finalize を待つ。
            try:
                proc.wait(timeout=10)
            except subprocess.TimeoutExpired:
                proc.terminate()
                proc.wait()
    finally:
        # 録音後: 出力デバイスを元に戻す
        if prev_output:
            switch_audio_output(prev_output)
            info(f"出力デバイスを戻しました: {prev_output!r}")
    print()
    if not out.exists() or out.stat().st_size < 1024:
        die("録音ファイルが作成されませんでした。デバイスの使用状況を確認してください。")
    info(f"\033[32m録音完了\033[0m: {out}  ({out.stat().st_size//1024} KB)")

    # そのまま議事録生成
    if args.minutes is not None:
        title = args.minutes or out.stem
        # PATHに頼らず、自分の隣にある mtg-minutes を絶対パスで解決
        sibling = Path(__file__).resolve().parent / "mtg-minutes"
        exe = str(sibling) if sibling.exists() else MTG_MINUTES
        info(f"議事録を生成します: {exe} {out} --title \"{title}\"")
        os.execvp(exe, [exe, str(out), "--title", title])
    else:
        print(f"\n次のコマンドで議事録化できます:")
        print(f"  mtg-minutes {out} --title \"会議名\"")


if __name__ == "__main__":
    main()
