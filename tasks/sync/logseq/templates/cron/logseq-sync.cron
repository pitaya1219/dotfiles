# Logseq Sync Cron Job
# Generated by task sync:logseq:schedule:cron
# Edit with caution

PATH=__HOME__/.nix-profile/bin:__PATH__
LOGSEQ_LOCAL=__LOGSEQ_LOCAL__
LOGSEQ_REMOTE=__LOGSEQ_REMOTE__
DOTFILES_DIR=__DOTFILES_DIR__

# Sync every __CRON_INTERVAL__ minutes
*/__CRON_INTERVAL__ * * * * __DOTFILES_DIR__/bin/task sync:logseq >> __LOG_FILE__ 2>> __LOG_FILE_ERROR__
