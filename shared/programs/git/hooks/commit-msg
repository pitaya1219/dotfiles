#!/bin/sh
# Git commit-msg hook to prevent AI tool attribution in commit messages
# This enforces the project rule: NO AI assistant references/attribution in commits

COMMIT_MSG_FILE="$1"

# Check for AI tool attribution patterns (case-insensitive)
# Only block specific attribution patterns, not general mentions of AI tools
AI_ATTRIBUTION_PATTERNS="Co-Authored-By.*(mistral|vibe|claude|claude-code|opencode|github-copilot|copilot|ai)|Generated by.*(mistral|vibe|claude|claude-code|opencode|github-copilot|copilot|ai)|Created by.*(mistral|vibe|claude|claude-code|opencode|github-copilot|copilot|ai)"

if grep -qiE "$AI_ATTRIBUTION_PATTERNS" "$COMMIT_MSG_FILE"; then
  echo ""
  echo "❌ ERROR: Commit message contains AI tool attribution!"
  echo ""
  echo "The following attribution patterns are NOT allowed in commit messages:"
  echo "  - Co-Authored-By: Mistral Vibe / Claude Code / etc."
  echo "  - Generated by Mistral Vibe / Claude Code / etc."
  echo "  - Created by Mistral Vibe / Claude Code / etc."
  echo ""
  echo "General mentions of AI tools (e.g., 'feat: Add Mistral API support') are allowed."
  echo "Only explicit AI attribution/co-authoring is blocked."
  echo ""
  echo "Offending commit message:"
  echo "---"
  cat "$COMMIT_MSG_FILE"
  echo "---"
  exit 1
fi

exit 0
